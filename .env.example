# Required — get your key at console.anthropic.com
ANTHROPIC_API_KEY=your_key_here

# Required — generate with: openssl rand -hex 32
JWT_SECRET=your_long_random_secret_here

# Optional — defaults shown
PORT=3001
DB_PATH=./db/plains.db
NODE_ENV=development
POLL_INTERVAL_MINUTES=30
MAX_ENRICHMENT_BATCH=10

# ── PHASE 2: SEO and social sharing (required for Phase 2) ───────────────────
SITE_URL=http://13.239.47.95/
VITE_SITE_URL=http://13.239.47.95/

# ── PHASE 2: Telegram admin bot (optional) ───────────────────────────────────
# Get TELEGRAM_BOT_TOKEN from @BotFather on Telegram
# Get TELEGRAM_ADMIN_USER_ID from @userinfobot on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ADMIN_USER_ID=your_numeric_telegram_id
